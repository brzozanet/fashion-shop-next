{
  "name": "fashion-shop-next",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "cp": "^0.2.0",
    "npm-run-all": "^4.1.5"
  },
  "scripts": {
    "reset": "cp \"./backend/backup/original_db.json\" ./backend/db.json",
    "frontend": "npm run dev --workspace=frontend",
    "backend": "npm run dev --workspace=backend",
    "dev": "npm-run-all --parallel frontend backend",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  }
}
